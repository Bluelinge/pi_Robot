[Unit]
Description=Pi Robot Control Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/pi_robot
EnvironmentFile=/opt/pi_robot/.env
ExecStart=/usr/bin/python3 -m pi_robot.main
Restart=always
RestartSec=2
User=pi

[Install]
WantedBy=multi-user.target
